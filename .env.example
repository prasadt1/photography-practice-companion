# Google Cloud
GOOGLE_CLOUD_PROJECT=practice-companion-hackathon
# Path is resolved from repo root (playground runs in app/ but key lives at project root)
GOOGLE_APPLICATION_CREDENTIALS=./gcp-service-account.json
# Regional Vertex services (embeddings, GCS, Agent Engine co-location)
VERTEX_AI_REGION=us-central1
# Gemini 3.x reasoning — must use global endpoint (see docs/decisions.md ADR-010)
VERTEX_AI_GEMINI_LOCATION=global
# Prefer 3.1 Pro (current); shorthand "gemini-3-pro" is not a valid Vertex model ID
GEMINI_MODEL=gemini-3.1-pro-preview
EMBEDDING_MODEL=multimodalembedding@001

# MongoDB Atlas (Flex, europe-west3 — see docs/mongodb-setup.md)
# Quote the URI if the password contains & $ # ! or spaces (bash cannot "source" bare &).
MONGODB_URI='mongodb+srv://USERNAME:PASSWORD@practice-photography-companion-m.e5tn2tc.mongodb.net/practice_companion?retryWrites=true&w=majority&appName=practice-photography-companion-mvp-cluster'
MONGODB_DB_NAME=practice_companion
MONGODB_ATLAS_CLIENT_ID=mdb_sa_id_xxxxxxxxxxxxx
MONGODB_ATLAS_CLIENT_SECRET=mdb_sa_sk_xxxxxxxxxxxxxxxxxxx
MONGODB_MCP_CONFIG_PATH=./mcp-config.json
# Map same values into mcp-config.json as MDB_MCP_CONNECTION_STRING, MDB_MCP_API_CLIENT_ID, MDB_MCP_API_CLIENT_SECRET

# Portfolio images (GCS — see docs/decisions.md ADR-002)
GCS_PORTFOLIO_BUCKET=practice-companion-portfolio
GCS_PORTFOLIO_PREFIX=originals

# Agent Engine / ADK
AGENT_ENGINE_LOCATION=us-central1
ORCHESTRATOR_AGENT_RESOURCE_NAME=

# Agent Builder Data Store
DATA_STORE_LOCATION=global
DATA_STORE_ID=

# Firebase Hosting
FIREBASE_PROJECT_ID=practice-companion-hackathon

# Frontend (empty = Vite proxy to api-dev on :8080)
VITE_API_BASE_URL=
VITE_USE_MOCK=false
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,https://practice-companion-hackathon.web.app,https://practice-companion-hackathon.firebaseapp.com
DEMO_USER_ID=

# Orchestrator — MongoDB MCP reads
ORCHESTRATOR_USE_MCP=true
# Local playground: stdio via mcp-config.json. Production: HTTP MCP Cloud Run (see scripts/deploy-mongodb-mcp.sh)
MONGODB_MCP_HTTP_URL=
MONGODB_MCP_API_KEY=
# Production: false (MCP required). Local dev without MCP service: true
MONGODB_MCP_ALLOW_PYMONGO_FALLBACK=true
MONGODB_MCP_USE_GCP_IDENTITY=true
MONGODB_MCP_HTTP_TIMEOUT_SEC=120

# Production: fail loud when Atlas Vector Search / Atlas Search unavailable (item 11)
MONGODB_REQUIRE_ATLAS_FEATURES=false

# Change stream listener debounce (seconds)
CHANGE_STREAM_DEBOUNCE_SEC=5

# Firebase Auth (web) — optional; leave empty for DEMO_USER_ID-only demo
# Populate from Firebase web app: bash scripts/sync-firebase-vite-env.sh
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=practice-companion-hackathon
